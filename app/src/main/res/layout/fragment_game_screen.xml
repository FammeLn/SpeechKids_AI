<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFF7ED"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ПОВТОРИ ЗВУК"
        android:textAlignment="center"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#F97316" />

    <ImageView
        android:id="@+id/characterImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:src="@android:drawable/ic_dialog_info" />

    <TextView
        android:id="@+id/wordCountText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textColor="#64748B"
        android:text="Слов: 0" />

    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/spacing_xl">

        <View
            android:id="@+id/micPulse"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@android:drawable/ic_menu_call"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recordButton"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="ЗАПИСАТЬ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/xpText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:text="XP: 0" />
</LinearLayout>


