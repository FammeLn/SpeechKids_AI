<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/child_bg">

    <!-- STATE 1: WELCOME SCREEN -->
    <LinearLayout
        android:id="@+id/gameWelcomeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Рычащие джунгли"
            android:textColor="@color/primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Помоги тигрёнку научиться рычать!"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="@color/child_accent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🐯"
                android:textSize="110sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/playButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="НАЧАТЬ ИГРУ!"
            android:textSize="22sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/primary" />
    </LinearLayout>

    <!-- STATE 2: PLAYING SCREEN -->
    <LinearLayout
        android:id="@+id/gamePlayingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <!-- Top stats (Stars & progress) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/gameStarsCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 0"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Задание 1 из 3"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- XP Progress Bar -->
        <ProgressBar
            android:id="@+id/gameProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:max="3"
            android:progress="0"
            android:progressDrawable="@android:drawable/progress_horizontal" />

        <!-- Mascot representation -->
        <TextView
            android:id="@+id/mascotView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="🐯"
            android:textSize="120sp" />

        <!-- Prompt phrase -->
        <TextView
            android:id="@+id/targetTextPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Повтори слово:"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/targetWordText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Р-Р-РЫБА"
            android:textAlignment="center"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Recording Indicator -->
        <TextView
            android:id="@+id/recordingStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Нажми кнопку и говори"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Pulsating Microphone Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/micRecordButton"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:gravity="center"
            android:text="🎙️"
            android:textSize="36sp"
            app:cornerRadius="48dp"
            app:backgroundTint="@color/primary" />
    </LinearLayout>

    <!-- STATE 3: RESULTS SCREEN -->
    <LinearLayout
        android:id="@+id/gameResultContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Супер!"
            android:textColor="@color/success"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Тигрёнок очень рад!"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <!-- 3 Stars -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="⭐⭐⭐"
            android:textSize="64sp" />

        <!-- Rewards Details -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/child_accent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Награда:"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+15 Очков (XP)"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/finishGameButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="В ГЛАВНОЕ МЕНЮ"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />
    </LinearLayout>
</FrameLayout>
